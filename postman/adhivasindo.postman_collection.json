  "info": {
    "_postman_id": "9e6be84d-3c0d-4b88-8d85-6e0f4a0b4a7f",
    "name": "Adhivasindo API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "const token = response.token || (response.data && response.data.token);",
              "if (token) {",
              "  pm.collectionVariables.set('token', token);",
              "  pm.test('Token disimpan ke collection variable', function () {",
              "    pm.expect(pm.collectionVariables.get('token')).to.eql(token);",
              "  });",
              "} else {",
              "  pm.test('Token tidak ditemukan di response', function () {",
              "    pm.expect.fail('Response tidak memiliki field token');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
